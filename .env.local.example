# ===========================================
# AppleWalls 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.local.example .env.local

# ===========================================
# 公共环境变量（客户端可访问）
# ===========================================

# 广告配置
# 设置为 true 启用广告
NEXT_PUBLIC_ENABLE_ADS=true

# 管理员链接
# 设置为 true 在导航栏显示管理员入口链接
NEXT_PUBLIC_ENABLE_ADMIN_LINK=true


# ===========================================
# 认证配置（仅服务端）
# ===========================================

# JWT密钥（请使用强随机字符串，至少32位）

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# 会话过期时间（小时）

# ===========================================
# 存储配置（生产环境）
# ===========================================

# 存储提供商类型：'r2'（仅支持 Cloudflare R2）
STORAGE_PROVIDER_PROD=r2

# --- Cloudflare R2 配置 ---
# R2 Access Key ID
R2_ACCESS_KEY_ID_PROD=your-r2-access-key-id

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY_PROD=your-r2-secret-access-key

# R2 存储桶名称
R2_BUCKET_NAME_PROD=your-r2-bucket-name

# R2 端点地址（格式：https://your-account-id.r2.cloudflarestorage.com）
R2_ENDPOINT_PROD=https://your-account-id.r2.cloudflarestorage.com





# ===========================================
# 配置说明
# ===========================================
# 1. R2配置说明：
#    - 默认使用私有存储桶和签名URL（代码中已设置默认值：isPrivate=true）
#    - 如需使用公开存储桶，需要修改代码中的默认值
#    - 默认配置：region=auto, isPrivate=true, urlExpires=3600, publicDomain=空#    - R2 endpoint URL只能用于API操作，不能用于公开访问
#
# 2. 生产环境安全建议：
#    - 使用强密码（至少12位，包含大小写字母、数字、特殊字符）
#    - JWT密钥长度至少32位
#    - 定期更换密码和密钥
#    - 配置IP白名单
#    - 启用HTTPS
#    - 定期备份数据
