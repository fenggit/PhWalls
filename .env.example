# ===========================================
# AppleWalls 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.example .env.local

# ===========================================
# Cloudflare R2 配置 - 正式环境
# ===========================================
# R2 Access Key ID（从 Cloudflare Dashboard 获取）
R2_ACCESS_KEY_ID_PROD=your_r2_access_key_id

# R2 Secret Access Key（从 Cloudflare Dashboard 获取）
R2_SECRET_ACCESS_KEY_PROD=your_r2_secret_access_key

# R2 存储桶名称
R2_BUCKET_NAME_PROD=your_r2_bucket_name

# R2 API 端点地址（格式：https://账户ID.r2.cloudflarestorage.com）
R2_ENDPOINT_PROD=https://your_account_id.r2.cloudflarestorage.com

# R2 区域（通常设置为 auto）
R2_REGION_PROD=auto

# R2 是否为私有存储桶（true=私有空间，false=公开空间）
# 私有空间需要使用签名URL访问，更安全
R2_IS_PRIVATE_PROD=true

# R2 私有URL过期时间（秒，默认3600秒=1小时）
R2_URL_EXPIRES_PROD=3600

# ===========================================
# 功能开关配置
# ===========================================
# 是否启用广告功能
# 设置为 'true' 启用，'false' 或未设置则禁用
NEXT_PUBLIC_ENABLE_ADS=true

# ===========================================
# 配置说明
# ===========================================
# 1. R2 配置说明：
#    - R2_ENDPOINT_PROD: R2 API端点，格式为 https://账户ID.r2.cloudflarestorage.com
#    - R2_REGION_PROD: 通常设置为 auto
#    - R2_IS_PRIVATE_PROD: true=私有空间（使用签名URL），false=公开空间（直接访问）
#    - R2_URL_EXPIRES_PROD: 私有URL过期时间（秒），建议设置为3600（1小时）
#
# 2. 私有存储桶配置：
#    - 私有空间更安全，需要使用签名URL访问
#    - 签名URL会自动过期，防止未授权访问
#    - 建议生产环境使用私有存储桶
#    - 签名URL使用 R2_ENDPOINT_PROD 作为基础URL，不需要配置自定义域名
#
# 3. CORS 配置（重要）：
#    如果遇到图片预览或下载失败，需要配置 R2 存储桶的 CORS 规则
#    使用 wrangler CLI 配置：
#    wrangler r2 bucket cors put your_bucket_name --rules ./cors.json
#
# 4. 生产环境安全建议：
#    - 使用强密码保护 R2 Access Key
#    - 定期更换 Access Key
#    - 配置 IP 白名单（如果可能）
#    - 启用 HTTPS
#    - 定期备份数据
